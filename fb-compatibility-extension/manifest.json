{
  "manifest_version": 3,
  "name": "Facebook Birthday Compatibility Scraper",
  "version": "1.0",
  "description": "Scrapes Facebook birthdays and redirects to your compatibility app.",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": ["*://*.facebook.com/*", "http://localhost:3000/*", "https://saki-beta-five.vercel.app/*"],
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["env.config.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon128.png"
  }
}
